{
  "info": {
    "name": "Online Voting API",
    "description": "Коллекция для проверки API курсовой работы: категории, номинации, фильтры, голосование.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "csrf_token",
      "value": ""
    },
    {
      "key": "session_id",
      "value": ""
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Categories list",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}"
          }
        ],
        "url": "{{base_url}}/api/categories/?is_active=true&ordering=-total_votes"
      }
    },
    {
      "name": "Create category",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRFToken",
            "value": "{{csrf_token}}"
          },
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}; csrftoken={{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Проекты\",\n  \"description\": \"Голосование за лучшие проекты\",\n  \"is_active\": true,\n  \"is_featured\": true,\n  \"priority\": 10,\n  \"color\": \"#0078d4\"\n}"
        },
        "url": "{{base_url}}/api/categories/"
      }
    },
    {
      "name": "Nominations open now",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}"
          }
        ],
        "url": "{{base_url}}/api/nominations/open_now/"
      }
    },
    {
      "name": "Filter nominations by rating",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}"
          }
        ],
        "url": "{{base_url}}/api/nominations/?min_rating=4&voting_open=true"
      }
    },
    {
      "name": "Vote for nomination",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-CSRFToken",
            "value": "{{csrf_token}}"
          },
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}; csrftoken={{csrf_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Очень понравилось\"\n}"
        },
        "url": "{{base_url}}/api/nominations/1/vote/"
      }
    },
    {
      "name": "My votes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}"
          }
        ],
        "url": "{{base_url}}/api/votes/?min_rating=4"
      }
    },
    {
      "name": "Top rated",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "sessionid={{session_id}}"
          }
        ],
        "url": "{{base_url}}/api/nominations/top_rated/"
      }
    }
  ]
}
